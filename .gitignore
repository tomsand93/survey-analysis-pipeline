# Ignore everything by default
*

# Allow this file
!.gitignore

# Allow top-level README
!README.md

# Allow data/ and only its intended contents
!data/
!data/*.py
!data/sample_data.xlsx

# Allow pipeline/ and only Python scripts
!pipeline/
!pipeline/*.py

# Allow .gitkeep in output directories (so empty dirs are tracked)
!output/
!output/.gitkeep
!intermediate/
!intermediate/.gitkeep
!processed_data/
!processed_data/.gitkeep
!visualizations/
!visualizations/.gitkeep
!visualizations/Enhanced/
!visualizations/Enhanced/*.py
!visualizations/Enhanced/*.png

# Allow tests/ and CI workflow
!tests/
!tests/*.py
!.github/
!.github/workflows/
!.github/workflows/*.yml
!requirements.txt
